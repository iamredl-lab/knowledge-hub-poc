{
  "name": "knowledge-hub-poc",
  "version": "0.1.0",
  "private": true,
  "description": "Collaborative Docs POC — KB-ядро экосистемы Uni.Verse",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "oxlint --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint --fix --no-error-on-unmatched-pattern",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.0"
}
